# =============================================================================
# Copy this file to .env.local (which is gitignored) and fill in real values.
# Production values are configured in the Vercel dashboard.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project URL and publishable key are safe to commit (used in the browser).
NEXT_PUBLIC_SUPABASE_URL=https://imxxiaaezsyteuwbwhvo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Eq7TkodcGHvBGgulQS-DUA_MG-FBxuS

# Server-only. Optional in Phase 4 (Drizzle pooler connection already
# bypasses RLS via the `postgres` role). Wire when you need to call admin
# auth APIs from server code. Get from Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Postgres ----------------------------------------------------------------
# Runtime queries from server code (webhooks, server actions reading the
# vault) — use the Supabase TRANSACTION pooler.
# Settings → Database → Connection string → "Transaction" pooler (port 6543).
# IMPORTANT: lib/db/client.ts sets prepare:false because the transaction
# pooler does not support prepared statements.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Schema migrations (drizzle-kit) — use the DIRECT connection.
# Settings → Database → Connection string → "Direct connection" (port 5432).
DIRECT_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# --- App ---------------------------------------------------------------------
# Public base URL of the app — used to build the Telegram webhook URL when
# you connect a bot. In dev, expose localhost via `ngrok http 3000` and put
# the https URL here. In Vercel prod, set to the deployed URL.
APP_URL=http://localhost:3000

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
